package dledger:plugin@0.1.0;

world handler {
    // Host-provided capabilities (imports) - more restricted than source
    import ledger-read;
    import plugin-storage;
    import logging;

    // Plugin-exported interfaces
    export handler-ops;
    export metadata;
}

/// Core handler operations exported by the plugin.
interface handler-ops {
    use types.{config-field, host-error};

    /// Return the configuration schema for this handler.
    config-schema: func() -> list<config-field>;

    /// Called after the user fills in config.
    configure: func(config: list<tuple<string, string>>) -> result<_, string>;

    /// Process ledger data and return a JSON result.
    /// The params argument is a JSON string with handler-specific parameters.
    process: func(params: string) -> result<string, string>;

    /// Generate a report in the specified format.
    /// Format is one of: "json", "csv", "pdf"
    /// Returns the raw bytes of the report.
    generate-report: func(format: string, params: string) -> result<list<u8>, string>;
}
