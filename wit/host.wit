package dledger:plugin@0.1.0;

/// Read-only access to the ledger.
interface ledger-read {
    use types.{account-info, currency-balance, query-params, transaction, host-error};

    /// List all accounts visible to this plugin.
    list-accounts: func() -> result<list<account-info>, host-error>;

    /// Get a single account by ID.
    get-account: func(id: string) -> result<option<account-info>, host-error>;

    /// Query transactions matching the given parameters.
    query-transactions: func(params: query-params) -> result<list<transaction>, host-error>;

    /// Get the balance of an account (optionally at a specific date).
    get-balance: func(account-id: string, as-of: string) -> result<list<currency-balance>, host-error>;

    /// Get the balance including all child accounts.
    get-balance-with-children: func(account-id: string, as-of: string) -> result<list<currency-balance>, host-error>;

    /// Get an exchange rate between two currencies on a date.
    get-exchange-rate: func(from-currency: string, to-currency: string, date: string) -> result<option<string>, host-error>;
}

/// Write access to the ledger (transactions enter "pending" status for user review).
interface ledger-write {
    use types.{transaction, price-point, host-error};

    /// Submit transactions for user review. Returns the number accepted.
    /// Transactions created by plugins always enter "pending" status.
    submit-transactions: func(transactions: list<transaction>) -> result<u32, host-error>;

    /// Record price/exchange rate data points.
    submit-prices: func(prices: list<price-point>) -> result<u32, host-error>;

    /// Ensure an account exists, creating it if needed.
    /// The host decides the account type based on the full-name path.
    ensure-account: func(full-name: string, account-type: string) -> result<string, host-error>;
}

/// HTTP client proxied through the host with domain allowlist enforcement.
interface http-client {
    use types.{http-request, http-response, host-error};

    /// Send an HTTP request. The host enforces the domain allowlist
    /// and rate limits declared in the plugin manifest.
    send: func(request: http-request) -> result<http-response, host-error>;
}

/// Scoped key-value storage for plugin state persistence.
interface plugin-storage {
    use types.{host-error};

    /// Get a value by key (scoped to this plugin).
    get: func(key: string) -> result<option<string>, host-error>;

    /// Set a value by key (scoped to this plugin).
    set: func(key: string, value: string) -> result<_, host-error>;

    /// Delete a key.
    delete: func(key: string) -> result<_, host-error>;

    /// List all keys (scoped to this plugin).
    list-keys: func() -> result<list<string>, host-error>;
}

/// Structured logging routed to the host's tracing system.
interface logging {
    /// Log at debug level.
    debug: func(message: string);

    /// Log at info level.
    info: func(message: string);

    /// Log at warn level.
    warn: func(message: string);

    /// Log at error level.
    error: func(message: string);
}
