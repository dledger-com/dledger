{
  "name": "dledger",
  "version": "0.2.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:web": "ADAPTER=cloudflare bun run build",
    "build:demo-db": "bun scripts/build-demo-db.ts",
    "build:demo": "bun run build:demo-db && VITE_DEMO_MODE=true ADAPTER=cloudflare bun run build",
    "e2e": "playwright test",
    "tauri": "tauri",
    "postinstall": "cp node_modules/sql.js/dist/sql-wasm.wasm static/sql-wasm.wasm && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs static/pdf.worker.min.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@inlang/paraglide-js": "^2.15.1",
    "@noble/secp256k1": "^3.0.0",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/virtual-core": "^3.13.19",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "bits-ui": "^2.15.5",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "decimal.js-light": "^2.5.1",
    "dompurify": "^3.3.3",
    "fflate": "^0.8.2",
    "layerchart": "^2.0.0-next.46",
    "lucide-svelte": "^0.563.0",
    "marked": "^17.0.5",
    "mode-watcher": "^1.1.0",
    "pdfjs-dist": "^4.9.155",
    "shiki": "^4.0.2",
    "sql.js": "^1.14.0",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/dompurify": "^3.2.0",
    "@types/uuid": "^11.0.0",
    "clsx": "^2.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "typescript": "~5.6.2",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
